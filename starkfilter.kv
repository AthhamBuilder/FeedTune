#:import dp kivy.metrics.dp
#:import MDBoxLayout kivymd.uix.boxlayout.MDBoxLayout
#:import MDScrollView kivymd.uix.scrollview.MDScrollView
#:import MDIconButton kivymd.uix.button.MDIconButton
#:import MDLabel kivymd.uix.label.MDLabel
#:import MDTextField kivymd.uix.textfield.MDTextField
#:import MDCard kivymd.uix.card.MDCard
#:import FloatLayout kivy.uix.floatlayout.FloatLayout
#:import MDGridLayout kivymd.uix.gridlayout.MDGridLayout


<MainScreen>:
    canvas.before:
        Color:
            rgba: 0.12, 0.12, 0.12, 1  # Dark background
        Rectangle:
            size: self.size
            pos: self.pos

    FloatLayout:
        # --- Header with gradient effect ---
        MDBoxLayout:
            id: header
            orientation: "vertical"
            size_hint_y: None
            height: dp(120)
            pos_hint: {"top": 1, "x": 0}
            padding: dp(16)
            spacing: dp(12)

            canvas.before:
                Color:
                    rgba: 0.15, 0.15, 0.15, 1  # Slightly lighter dark
                Rectangle:
                    size: self.size
                    pos: self.pos

            # --- Title ---
            MDLabel:
                text: "FeedTune"
                font_style: "H5"
                size_hint_y: None
                height: dp(36)
                theme_text_color: "Primary"
                bold: True

            # --- Search Bar ---
            MDBoxLayout:
                orientation: "horizontal"
                spacing: dp(10)
                size_hint_y: None
                height: dp(52)

                MDTextField:
                    id: search_field
                    hint_text: "Search By Keywords..."
                    mode: "rectangle"
                    size_hint_x: 1
                    text_color: 1, 1, 1, 1
                    hint_text_color_focus: 0.7, 0.7, 0.7, 1
                    hint_text_color_normal: 0.5, 0.5, 0.5, 1
                    line_color_focus: 0, 188/255, 212/255, 1
                    line_color_normal: 0.3, 0.3, 0.3, 1
                    cursor_color: 0, 188/255, 212/255, 1
                    background_color: 0.2, 0.2, 0.2, 1
                    padding: dp(12), dp(8)
                    multiline: False

                MDIconButton:
                    icon: "magnify"
                    size_hint: None, None
                    size: dp(50), dp(50)
                    md_bg_color: 0, 188/255, 212/255, 1  # Teal accent
                    radius: [8]
                    on_release: app.search_topics(search_field.text)

        # --- Collapsible Topic Sidebar ---
        MDScrollView:
            id: topic_scroll
            size_hint: 0.22, 0.8
            pos_hint: {"x": 0, "y": 0.05}
            
            canvas.before:
                Color:
                    rgba: 0.14, 0.14, 0.14, 1
                Rectangle:
                    size: self.size
                    pos: self.pos

            MDBoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                padding: dp(12)
                spacing: dp(8)
                adaptive_height: True

                MDLabel:
                    text: "Topics"
                    font_style: "Subtitle1"
                    size_hint_y: None
                    height: dp(32)
                    bold: True
                    theme_text_color: "Primary"

                MDGridLayout:
                    id: topic_list
                    cols: 1
                    adaptive_height: True
                    spacing: dp(10)
                    size_hint_y: None
                    height: self.minimum_height

        # --- Main Content Area ---
        MDScrollView:
            id: main_scroll
            size_hint: 0.78, 0.8
            pos_hint: {"x": 0.22, "y": 0.05}

            MDGridLayout:
                id: list_view
                cols: 1
                adaptive_height: True
                spacing: dp(12)
                padding: dp(16)
                size_hint_y: None
                height: self.minimum_height
